<?xml version="1.0" encoding="UTF-8"?>
<!--
  Whiteboard Example 1: 3-Member Truss System
  
  Geometry:
    Center node (free) at (0,0)
    Left member: 8m, 30 deg above negative x-axis
    Right member: 5m, 45 deg above positive x-axis
    Bottom member: 6m, vertical
    
  Properties:
    E = 200 GPa
    alpha = 1.2e-5 /°C
    A_left = 5000 mm²
    A_right = 4000 mm²
    A_bottom = 6000 mm²
    
  Loading:
    Uniform temperature change. To match the negative displacement 
    answers on the board (u = {-0.405, -0.070} mm). We use delta_T = +20.0 °C.
-->
<structural_model name="Eg1_3_Truss_Temp">
  <metadata>
    <title>Example 1: 3 Truss System with Temperature Load</title>
  </metadata>
  <units length="m" force="kN" temperature="C"/>
  <materials>
    <material id="steel" name="Steel 200 GPa" E="2.0e8" alpha="1.2e-5"/>
  </materials>
  <sections>
    <section id="sec_left" A="0.005"/>
    <section id="sec_right" A="0.004"/>
    <section id="sec_bottom" A="0.006"/>
  </sections>
  <nodes>
    <!-- Central free node -->
    <node id="1" x="0.0" y="0.0"/>
    
    <!-- Support nodes calculated via trig -->
    <!-- N2: x = -8*cos(30), y = 8*sin(30) -->
    <node id="2" x="-6.928203" y="4.0"/>
    <!-- N3: x = 5*cos(45), y = 5*sin(45) -->
    <node id="3" x="3.535534" y="3.535534"/>
    <!-- N4: x = 0, y = -6 -->
    <node id="4" x="0.0" y="-6.0"/>
  </nodes>
  <elements>
    <truss id="T1" node_i="1" node_j="2" material="steel" section="sec_left"/>
    <truss id="T2" node_i="1" node_j="3" material="steel" section="sec_right"/>
    <truss id="T3" node_i="1" node_j="4" material="steel" section="sec_bottom"/>
  </elements>
  <boundary_conditions>
    <support node="2" type="pin"/>
    <support node="3" type="pin"/>
    <support node="4" type="pin"/>
  </boundary_conditions>
  <load_cases>
    <load_case id="LC1">
      <temperature_load type="uniform" element="T1" delta_T="20.0"/>
      <temperature_load type="uniform" element="T2" delta_T="20.0"/>
      <temperature_load type="uniform" element="T3" delta_T="20.0"/>
    </load_case>
  </load_cases>
</structural_model>