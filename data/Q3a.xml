<?xml version="1.0" encoding="UTF-8"?>
<!--
  Q3 (a) — PORTAL FRAME  (roller at both column bases)
  ════════════════════════════════════════════════════════════════════════
  Structure:

    N2 ────── N3
    │          │      h = 4 m
    │          │      b = 4 m
    N1        N4
    ○          ○
  roller    roller    (both restrain uy only; ux is FREE everywhere)

  DOF analysis:
    Total DOFs     : 4 nodes × 3 = 12
    Restrained     : roller_x at N1 (uy=1), roller_x at N4 (uy=1) → 2
    Free DOFs      : 10
    Horizontal restraint: NONE — no node has ux suppressed.

  ── ERROR ────────────────────────────────────────────────────────────
  RIGID BODY MOTION: The entire frame is free to translate in the
  global x-direction without resistance from any member or support.
  The assembled stiffness matrix K is SINGULAR (det K = 0).

  Expected error message:
    "Singular stiffness matrix detected. No boundary condition restrains
     horizontal translation (global x-direction). The structure can
     undergo unrestricted rigid body sway. Add at least one support with
     ux restrained (e.g., change a roller to a pin at one base node)."

  Applied load: 10 kN lateral at N2 — amplifies the singularity
  (a purely lateral load on an un-braced, un-anchored frame).
-->
<structural_model name="Q3a">

  <metadata>
    <title>Q3(a) — Portal Frame, Roller–Roller Bases (No Horizontal Restraint)</title>
    <description>
      1-bay portal frame. Both column bases are roller supports that
      restrain uy only. No ux restraint exists anywhere in the model.
      Expected: ERROR — singular K due to rigid body translation in x.
    </description>
  </metadata>

  <units length="m" force="kN"/>

  <materials>
    <material id="steel_200" name="Steel 200 GPa" E="2.0e8"/>
  </materials>

  <sections>
    <section id="sec1" name="Frame Section" A="1.0e-2" I="1.0e-4"/>
  </sections>

  <nodes>
    <node id="1"  x="0.0"  y="0.0"/>
    <node id="2"  x="0.0"  y="4.0"/>
    <node id="3"  x="4.0"  y="4.0"/>
    <node id="4"  x="4.0"  y="0.0"/>
  </nodes>

  <elements>
    <frame id="F1" node_i="1" node_j="2" material="steel_200" section="sec1"/>  <!-- Left  column -->
    <frame id="F2" node_i="2" node_j="3" material="steel_200" section="sec1"/>  <!-- Beam         -->
    <frame id="F3" node_i="3" node_j="4" material="steel_200" section="sec1"/>  <!-- Right column -->
  </elements>

  <boundary_conditions>
    <!-- roller_x: uy restrained, ux FREE — no horizontal anchor in the model -->
    <support node="1" type="roller_x"/>
    <support node="4" type="roller_x"/>
  </boundary_conditions>

  <load_cases>
    <load_case id="LC1" name="Lateral load — exposes missing horizontal restraint">
      <point_load node="2" fx="10.0" fy="0.0"/>
    </load_case>
  </load_cases>

</structural_model>
